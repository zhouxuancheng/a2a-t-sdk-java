# Copy this file to server.env before starting the a2a-java v1.0.0.Beta1 HTTP+JSON/REST sample server.
# The current Java sample uses a2a-t-server prompt validation with DeepSeek via the openai_compatible adapter.
A2AT_LANGUAGE=zh-CN
A2AT_PROMPT_SOURCE_TYPE=local_file
A2AT_PROMPT_RESOURCE_LOCAL_ROOT_DIR=../../../../../../a2a-t-resources/src/main/resources/prompt_resources
A2AT_LLM_PROVIDER=openai_compatible
A2AT_LLM_MODEL=deepseek-chat
A2AT_LLM_BASE_URL=https://api.deepseek.com
A2AT_LLM_API_KEY=sk-df51deb154dd483bb49f2508773f6679
A2AT_NEGOTIATION_STATE_STORE_TYPE=in_memory
A2AT_SAMPLE_HOST=127.0.0.1
A2AT_SAMPLE_PORT=26335
REGISTRY_CENTER_HOST=127.0.0.1
REGISTRY_CENTER_PORT=5001
