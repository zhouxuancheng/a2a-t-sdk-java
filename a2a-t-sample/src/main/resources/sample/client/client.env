# Copy this file to client.env before starting the a2a-java v1.0.0.Beta1 HTTP+JSON/REST sample client.
# The current Java sample uses a2a-t-client prompt generation with DeepSeek via the openai_compatible adapter.
A2AT_LANGUAGE=zh-CN
A2AT_PROMPT_SOURCE_TYPE=classpath
A2AT_PROMPT_RESOURCE_LOCAL_ROOT_DIR=
A2AT_LLM_PROVIDER=openai_compatible
A2AT_LLM_MODEL=deepseek-chat
A2AT_LLM_BASE_URL=https://api.deepseek.com
A2AT_LLM_API_KEY=sk-df51deb154dd483bb49f2508773f6679
A2AT_NEGOTIATION_STATE_STORE_TYPE=in_memory
REGISTRY_CENTER_HOST=127.0.0.1
REGISTRY_CENTER_PORT=5001
# Optional: query AgentCard directly from the sample server root instead of registry-center.
A2AT_SAMPLE_HOST=127.0.0.1
A2AT_SAMPLE_PORT=26335
