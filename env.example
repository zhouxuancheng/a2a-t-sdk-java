# Prompt runtime
# Controls the language used by prompt runtime components.
A2AT_LANGUAGE=en-US
# Selects the prompt source backend.
A2AT_PROMPT_SOURCE_TYPE=local_file
# Optional when A2AT_PROMPT_SOURCE_TYPE=local_file.
A2AT_PROMPT_RESOURCE_LOCAL_ROOT_DIR=

# Prompt compliance
# Enables or disables prompt compliance checks.
A2AT_PROMPT_COMPLIANCE_ENABLED=false

# LLM runtime
# Selects the LLM provider used by the shared client.
A2AT_LLM_PROVIDER=
# Selects the default model name for the configured provider.
A2AT_LLM_MODEL=
# API key for the configured LLM provider.
A2AT_LLM_API_KEY=
# Base URL for the configured LLM provider.
A2AT_LLM_BASE_URL=
# Optional maximum tokens for completion calls.
A2AT_LLM_MAX_TOKENS=2000
# Default sampling temperature.
A2AT_LLM_TEMPERATURE=0
# Request timeout in seconds.
A2AT_LLM_TIMEOUT_SECONDS=60
# Number of chat history messages to keep.
A2AT_LLM_HISTORY_WINDOW=10
# Maximum total number of tracked sessions.
A2AT_LLM_SESSION_MAX_TOTAL=300
# Maximum number of tracked sessions per provider.
A2AT_LLM_SESSION_MAX_PER_PROVIDER=100

# Negotiation
# Selects the negotiation state store implementation.
A2AT_NEGOTIATION_STATE_STORE_TYPE=in_memory
